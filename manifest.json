{
  "manifest_version": 3,
  "name": "Claude Usage",
  "version": "1.0.0",
  "description": "Simple Claude.ai usage monitor",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"]
    }
  ]
}
